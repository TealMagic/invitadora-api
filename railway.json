{
  "$schema": "https://railway.com/railway.schema.json",
  "deploy": {
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "services": {
    "api": {
      "startCommand": "python -m scripts.start_api"
    },
    "worker": {
      "startCommand": "python -m scripts.start_worker"
    }
  }
}
